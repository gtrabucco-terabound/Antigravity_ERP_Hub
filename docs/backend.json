
{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Un cliente corporativo o unidad de negocio en Terabound.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nombre comercial del cliente."
        },
        "tenantId": {
          "type": "string",
          "description": "Identificador único (ej: TC-00124)."
        },
        "status": {
          "type": "string",
          "enum": ["active", "suspended", "maintenance"]
        },
        "modules": {
          "type": "array",
          "description": "Lista de módulos habilitados para este cliente.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "status": { "type": "string" },
              "slug": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "tenantId"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/_gl_tenants/{tenantId}": {
      "schema": { "$ref": "#/backend/entities/Tenant" },
      "description": "Colección global de clientes del Hub."
    }
  }
}
